# ── Dev server ──────────────────────────────────────────────────────────────
API_SERVER_URL=http://localhost:3000
WS_SERVER_URL=ws://localhost:3001

# ── Bootstrap (admin account created on first pnpm dev start) ───────────────
BOOTSTRAP_ADMIN_EMAIL=admin@localhost
BOOTSTRAP_ADMIN_PASSWORD=admin123
BOOTSTRAP_ADMIN_NAME=Admin

# ── Agent token (written automatically by pnpm setup) ───────────────────────
# Leave blank until you run: pnpm setup
BOOTSTRAP_AGENT_TOKEN=
AGENT_TOKEN=

# ── Mention-watcher config ───────────────────────────────────────────────────
SETUP_EMAIL=admin@localhost
SETUP_PASSWORD=admin123
SETUP_NAME=Admin
SETUP_AGENT_NAME=claude-agent
MCP_SERVER_NAME=agent-chat

# Comma-separated channels for the watcher to join
WATCH_CHANNELS=general

# Milliseconds of output silence before injecting a mention prompt (default 800)
# INJECT_IDLE_MS=800

# ── Web client (Next.js) ─────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# ── Security ─────────────────────────────────────────────────────────────────
# IMPORTANT: Change JWT_SECRET before any public/production deployment
JWT_SECRET=dev-secret-change-in-production-min-32-chars!!

# Optional: persist in-memory state across restarts (dev only)
# PERSIST_FILE=./dev-state.json
